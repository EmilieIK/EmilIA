---
// Fil rouge du mémoire : 6 jalons (brief 04), liens-ancres vers les chapitres
// du plan. Vertical sur mobile, horizontal sur desktop. Navigation 100 % en
// ancres natives (le JS de Disclosure ne fait qu'ouvrir le panneau cible).
// TODO Émilie : valider le rattachement de chaque jalon au chapitre.
const jalons = [
  { nom: 'Terrain', ch: 2 },
  { nom: 'Problématisation', ch: 3 },
  { nom: 'Cadre théorique', ch: 5 },
  { nom: 'Expérience', ch: 4 },
  { nom: 'Résultats', ch: 11 },
  { nom: 'Recul', ch: 14 },
];
---
<nav class="fil-rouge-wrap" aria-label="Fil rouge du mémoire" id="fil-rouge">
  <ol class="fil-rouge">
    {jalons.map((j, i) => (
      <li class="fil-rouge__step">
        <a class="fil-rouge__link" href={`#ch-${j.ch}`}>
          <span class="fil-rouge__rank" aria-hidden="true">{i + 1}</span>
          <span class="fil-rouge__text">
            <span class="fil-rouge__name">{j.nom}</span>
            <span class="visually-hidden"> – aller au chapitre {j.ch}</span>
          </span>
        </a>
      </li>
    ))}
  </ol>
  <p class="fil-rouge__note">Ce fil articule terrain, théorisation et intervention.</p>
</nav>
