---
// Disclosure accessible et réutilisable (pattern WAI-ARIA).
// Le titre porte un <button aria-controls> ; l'attribut aria-expanded et l'état
// replié sont posés par JS au boot (progressive enhancement honnête : sans JS,
// le panneau reste visible et le bouton ne prétend pas à un état faux).
// Le comportement (clic, ancres, tout déplier) est géré par un unique script
// délégué ci-dessous (bundlé une seule fois par Astro).
interface Props {
  label: string;
  anchor: string;          // id stable, ex. "partie-1" ou "ch-7"
  level?: 3 | 4;           // niveau de titre (parties = 3, chapitres = 4)
}
const { label, anchor, level = 3 } = Astro.props;
const Heading = `h${level}` as const;
const btnId = `${anchor}-btn`;
const panelId = `${anchor}-panel`;
const lvl2 = level === 4 ? ' disclosure__heading--lvl2' : '';
---
<div class="disclosure" id={anchor}>
  <Heading class={`disclosure__heading${lvl2}`}>
    <button type="button" class="disclosure__btn" id={btnId} aria-controls={panelId}>
      <span class="disclosure__label">{label}</span>
      <svg class="disclosure__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 6 6 6-6 6"></path>
      </svg>
    </button>
  </Heading>
  <div id={panelId} class="disclosure__panel">
    <slot />
  </div>
</div>

<script>
  import '../scripts/disclosure.ts';
</script>
