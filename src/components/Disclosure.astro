---
// Disclosure accessible et réutilisable (pattern WAI-ARIA).
// Le titre porte un <button aria-controls> ; l'attribut aria-expanded et l'état
// replié sont posés par JS au boot (progressive enhancement honnête : sans JS,
// le panneau reste visible et le bouton ne prétend pas à un état faux).
// Le comportement (clic, ancres, tout déplier) est géré par un unique script
// délégué ci-dessous (bundlé une seule fois par Astro).
interface Props {
  label: string;
  anchor: string;          // id stable, ex. "partie-1" ou "ch-7"
  level?: 3 | 4;           // niveau de titre (parties = 3, chapitres = 4)
}
const { label, anchor, level = 3 } = Astro.props;
const Heading = `h${level}` as const;
const btnId = `${anchor}-btn`;
const panelId = `${anchor}-panel`;
const lvl2 = level === 4 ? ' disclosure__heading--lvl2' : '';
---
<div class="disclosure" id={anchor}>
  <Heading class={`disclosure__heading${lvl2}`}>
    <button type="button" class="disclosure__btn" id={btnId} aria-controls={panelId}>
      <span class="disclosure__label">{label}</span>
      <svg class="disclosure__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m9 6 6 6-6 6"></path>
      </svg>
    </button>
  </Heading>
  <div id={panelId} class="disclosure__panel">
    <slot />
  </div>
</div>

<script>
  // Script unique délégué (Astro le bundle une seule fois quel que soit le
  // nombre d'instances). Pilote toutes les Disclosure de la page.
  function panelOf(btn) {
    const id = btn.getAttribute('aria-controls');
    return id ? document.getElementById(id) : null;
  }
  function setOpen(btn, open) {
    const panel = panelOf(btn);
    btn.setAttribute('aria-expanded', String(open));
    if (panel) panel.classList.toggle('is-open', open);
  }
  const allBtn = document.querySelector('[data-disclosure-all]');
  function syncAll() {
    if (!allBtn) return;
    const btns = Array.from(document.querySelectorAll('.disclosure__btn'));
    const everyOpen = btns.length > 0 && btns.every((b) => b.getAttribute('aria-expanded') === 'true');
    allBtn.setAttribute('aria-pressed', String(everyOpen));
    allBtn.textContent = everyOpen ? 'Tout replier' : 'Tout déplier';
  }
  // Ouvre un panneau et tous ses panneaux parents (Disclosure imbriquées).
  function openWithAncestors(el) {
    let node = el;
    while (node) {
      if (node.classList && node.classList.contains('disclosure__panel')) {
        const controller = document.querySelector(`[aria-controls="${node.id}"]`);
        if (controller) setOpen(controller, true);
      }
      node = node.parentElement;
    }
  }

  // Boot : pose l'état replié honnête (aria-expanded=false ; le repli visuel
  // vient du CSS html.js). Sans JS, ce code ne s'exécute pas → panneaux visibles.
  document.querySelectorAll('.disclosure__btn').forEach((b) => b.setAttribute('aria-expanded', 'false'));
  syncAll();

  // Clic sur un bouton de disclosure → bascule.
  document.addEventListener('click', (e) => {
    const btn = (e.target instanceof Element) ? e.target.closest('.disclosure__btn') : null;
    if (!btn) return;
    setOpen(btn, btn.getAttribute('aria-expanded') !== 'true');
    syncAll();
  });

  // « Tout déplier / replier ».
  if (allBtn) {
    allBtn.addEventListener('click', () => {
      const expand = allBtn.getAttribute('aria-pressed') !== 'true';
      document.querySelectorAll('.disclosure__btn').forEach((b) => setOpen(b, expand));
      allBtn.setAttribute('aria-pressed', String(expand));
      allBtn.textContent = expand ? 'Tout replier' : 'Tout déplier';
    });
  }

  // Ancre vers un chapitre/partie replié : ouvrir (avec parents) puis focus.
  function revealHash() {
    const hash = location.hash;
    if (!hash || hash.length < 2) return;
    const target = document.getElementById(decodeURIComponent(hash.slice(1)));
    if (!target) return;
    const ownBtn = target.querySelector('.disclosure__btn');
    openWithAncestors(target.closest('.disclosure__panel'));
    if (ownBtn) {
      setOpen(ownBtn, true);
      ownBtn.focus();
    }
    syncAll();
  }
  window.addEventListener('hashchange', revealHash);
  window.addEventListener('load', revealHash);
</script>
