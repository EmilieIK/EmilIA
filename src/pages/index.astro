---
import Base from '../layouts/Base.astro';
import { url } from '../lib/paths';

const chips = ['FLE', 'Production écrite', 'IA générative', "Littératie de l'IA", 'Autonomie assistée'];

const piliers = [
  {
    index: '01',
    titre: 'Soutenance',
    href: '/soutenance',
    desc: 'La présentation orale structurée selon les attendus du jury, consultable et projetable en mode plein écran.',
  },
  {
    index: '02',
    titre: 'Mémoire',
    href: '/memoire',
    desc: 'Résumé, plan des trois parties, fil rouge terrain–théorie–expérience–résultats et glossaire.',
  },
  {
    index: '03',
    titre: 'Kit pédagogique',
    href: '/kit',
    desc: "Un scénario en 8 étapes alternant phases sans IA et recours ciblés à l'IA.",
  },
  {
    index: '04',
    titre: 'À propos',
    href: '/a-propos',
    desc: "Des TICE à l'IA, une même conviction : l'outil accompagne, il ne remplace pas.",
  },
];
---
<Base title="Production écrite en FLE & IA – Émilie Icyk">
  <section class="section hero">
    <div class="container">
      <p class="hero__eyebrow">Master 2 FLES · Université Grenoble Alpes · 2025-2026</p>
      <p class="hero__wordmark">Emil’IA</p>
      <h1>Production écrite en FLE et intelligence artificielle</h1>
      <p class="hero__subtitle">un scénario pour une autonomie assistée</p>

      <ul class="signature" aria-label="Fil conducteur du mémoire">
        <li>Révélateur</li>
        <li>Instrument secondaire</li>
        <li>Autonomie à construire</li>
      </ul>

      <div class="hero__cta">
        <a class="btn btn--primary" href={url('/kit')}>Découvrir le kit</a>
        <a class="btn btn--secondary" href={url('/soutenance')}>La soutenance</a>
      </div>

      <ul class="chips" aria-label="Champs du travail">
        {chips.map((c) => <li class="chip">{c}</li>)}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Explorer le site</h2>
      <ul class="cards">
        {piliers.map((p) => (
          <li>
            <a class="card" href={url(p.href)}>
              <span class="card__index" aria-hidden="true">{p.index}</span>
              <h3 class="card__title">{p.titre}</h3>
              <p class="card__desc">{p.desc}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <aside class="callout" aria-labelledby="anthropo-h">
        <h2 id="anthropo-h" class="callout__title">Une approche centrée sur l'humain</h2>
        <p>
          Depuis plus de vingt ans, des premiers usages des TICE pour la différenciation
          jusqu'aux IA génératives, une même conviction guide ce travail : le numérique n'a
          de valeur que s'il affine l'accompagnement, sans jamais remplacer l'activité de
          l'apprenant·e ni la médiation de l'enseignant·e. Les IA génératives déplacent
          pourtant cette question ancienne, car elles ne se contentent plus d'accompagner
          l'écriture : elles produisent du texte. Tout l'enjeu du scénario est de les garder
          secondaires – un appui révélateur, pour que le geste d'écrire reste celui de
          l'apprenant·e.
        </p>
      </aside>
    </div>
  </section>
</Base>
