---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/paths';

const parcours = (await getCollection('corpus')).sort((a, b) => a.id.localeCompare(b.id));

const tacheTitre: Record<string, string> = {
  B1: 'Sujet · niveau B1.2 · 180 à 220 mots',
  B2: 'Sujet · niveau B2.1 (Erasmus+) · 230 à 260 mots',
};
const tache: Record<string, string> = {
  B1: "Racontez une expérience importante de votre vie récente, vécue dans un contexte différent de celui de votre pays ou de votre environnement habituel (études, travail, mobilité, séjour à l'étranger, voyage long, etc.). Vous expliquerez comment cette expérience s'est construite au quotidien, en évoquant par exemple votre parcours d'études ou professionnel, votre manière de vivre et de vous loger, les relations sociales développées, votre rapport à la nourriture et aux habitudes culturelles, ou encore les déplacements qui ont marqué cette période.",
  B2: "Racontez votre expérience Erasmus en évoquant les moments marquants de votre séjour, vos attentes avant le départ, les difficultés rencontrées ainsi que ce que cette expérience vous a apporté sur le plan linguistique et personnel. Votre texte devra être clair, organisé et utiliser des connecteurs logiques variés.",
};

const splitParas = (s: string) => s.split('\n\n').map((p) => p.trim()).filter(Boolean);
const splitPoint = (pt: string): [string, string] => {
  const i = pt.indexOf(' : ');
  return i === -1 ? ['', pt] : [pt.slice(0, i), pt.slice(i + 3)];
};
---
<Base title="Exploration du corpus" description="Le corpus du mémoire : 15 parcours d'écriture anonymisés (B1 et B2), avec l'analyse de synthèse, la grille d'analyse codée et un échange avec l'IA.">
  <section class="section container">
    <nav aria-label="Fil d'Ariane" class="kw-label">
      <a href={url('/memoire')}>Le mémoire</a> · Exploration du corpus
    </nav>
    <h1>Exploration du corpus</h1>

    <aside class="callout" role="note" aria-labelledby="corpus-note-h">
      <p id="corpus-note-h" class="callout__title">15 parcours, deux groupes, des données anonymisées</p>
      <p class="prose">
        Ce corpus rassemble les parcours d'écriture de quinze étudiant·es – sept de niveau B1, huit de
        niveau B2 – recueillis lors de l'expérimentation du kit, dans le cadre d'une recherche-action.
        Il permet de comparer deux degrés de guidage enseignant : dans le groupe B1, les erreurs ont été
        codées et signalées par l'enseignante dès le premier jet ; dans le groupe B2, le repérage reposait
        surtout sur la correction entre pairs avant le recours à l'IA.
      </p>
      <p class="prose">
        Les productions manuscrites ne sont pas reproduites. Pour chaque parcours – désigné par un
        <strong>identifiant neutre, sans prénom</strong> – on présente l'<strong>analyse de synthèse</strong>,
        la <strong>grille d'analyse codée</strong> et un <strong>extrait d'échange avec l'IA</strong> recentré
        sur la langue. Les codes de la grille renvoient aux étapes du kit pédagogique.
      </p>
    </aside>

    <div class="corpus-selecteur" role="region" aria-labelledby="sel-h">
      <h2 id="sel-h">Choisir un parcours à explorer</h2>
      <p class="corpus-selecteur__row">
        <label for="cas-select">Parcours anonymisé</label>
        <select id="cas-select" data-cas-select>
          {parcours.map((p) => <option value={p.id}>{p.id} – niveau {p.data.niveau}</option>)}
        </select>
      </p>
      <p class="corpus-selecteur__note">Identifiants neutres, sans prénom (anonymisation).</p>
      <p class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" data-cas-live></p>
    </div>
  </section>

  {parcours.map((p) => (
    <article class="section container cas" data-cas-panel data-cas-id={p.id} aria-labelledby={`cas-${p.id}-h`}>
      <header class="cas-entete">
        <p class="card__index" aria-hidden="true">{p.id}</p>
        <h2 id={`cas-${p.id}-h`} tabindex="-1">Parcours {p.id} <span class="cas-niveau">niveau {p.data.niveau}</span></h2>
        <details class="corpus-sujet">
          <summary>{tacheTitre[p.data.niveau]}</summary>
          <p class="prose">{tache[p.data.niveau]}</p>
        </details>
      </header>

      <section aria-labelledby={`syn-${p.id}-h`}>
        <h3 id={`syn-${p.id}-h`}>Analyse de synthèse</h3>
        {splitParas(p.data.synthese).map((para) => <p class="prose">{para}</p>)}
      </section>

      <section aria-labelledby={`gr-${p.id}-h`}>
        <h3 id={`gr-${p.id}-h`}>Grille d'analyse codée</h3>
        <div class="grille-codee-v2">
          {p.data.grille.map((g) => (
            <div class="grille-etape">
              <h4 class="grille-etape__titre">{g.etape}</h4>
              <ul class="grille-points">
                {g.points.map((pt) => {
                  const [code, reste] = splitPoint(pt);
                  return <li>{code && <code>{code}</code>} {reste}</li>;
                })}
              </ul>
            </div>
          ))}
        </div>
      </section>

      {p.data.echangeIA && (
        <section aria-labelledby={`ia-${p.id}-h`}>
          <h3 id={`ia-${p.id}-h`}>Un échange avec l'IA <span class="cas-souslabel">{p.data.echangeIA.contexte}</span></h3>
          <div class="ia-echange">
            <p class="ia-echange__prompt"><span class="ia-echange__role">Étudiant·e :</span> {p.data.echangeIA.etudiant}</p>
            <p class="ia-echange__reponse"><span class="ia-echange__role">IA :</span> {p.data.echangeIA.ia}</p>
          </div>
        </section>
      )}
    </article>
  ))}

  <section class="section container">
    <p class="prose"><a href={url('/memoire')}>Revenir au mémoire</a></p>
  </section>
</Base>

<script>
  import '../../scripts/corpus.ts';
</script>
