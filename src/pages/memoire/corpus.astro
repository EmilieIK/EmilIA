---
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/paths';

// Synthèse agrégée du corpus. AUCUNE donnée individuelle : pas de prénom ni
// d'identifiant de parcours, pas de métadonnée (langue, nationalité, ville, statut),
// pas de verbatim attribuable. Le corpus détaillé reste dans le mémoire (non publié).

const chiffres = [
  {
    titre: "Ce que l'IA a pris en charge",
    stats: [
      { label: 'correction demandée', num: '15/15' },
      { label: 'reformulation', num: '14/15' },
      { label: 'organisation du texte', num: '2/15' },
    ],
  },
  {
    titre: 'Comment les suggestions ont été reçues',
    stats: [
      { label: 'reprise directe', num: '10/15' },
      { label: 'acceptation peu critique', num: '11/15' },
      { label: 'rejet dans les traces', num: '0/15' },
    ],
  },
  {
    titre: 'La qualité des demandes (prompts)',
    stats: [
      { label: 'prompt précis & contextualisé', num: 'B1 1/7 · B2 7/8' },
      { label: 'prompt élaboré observé', num: '0/15' },
    ],
  },
];

const dementis = [
  {
    num: 'Démenti 1',
    titre: "L'effet de l'IA n'est pas isolable du cadrage",
    desc: "Même outil, même scénario, deux groupes : des usages opposés, selon ce que l'enseignant·e met au premier plan.",
  },
  {
    num: 'Démenti 2',
    titre: "L'autonomie : une compétence à construire, pas un état",
    desc: 'Usage de surface, reprises fréquentes, rares mises à distance.',
  },
  {
    num: 'Démenti 3',
    titre: 'Un plafond dans les usages observés',
    desc: "On corrige et on reformule, on ne réécrit pas encore : la littératie de l'IA reste en construction.",
  },
];

const phenomenes = [
  {
    titre: 'La forme plausible mais fausse',
    desc: "Interrogée sur un mot inexistant, l'IA propose une correction utile mais affirme à tort que le mot existe : elle produit de la forme sans comprendre.",
  },
  {
    titre: 'Le « dialogue de sourds »',
    desc: "Sans les mots pour nommer sa difficulté (le métalangage), l'échange avec l'IA tourne court.",
  },
  {
    titre: 'Le « texte lissé »',
    desc: "Un texte devient plus correct, mais perd une formulation personnelle, une voix : l'amélioration peut aussi appauvrir.",
  },
];

const concepts = [
  { nom: 'Révélateur', desc: "l'IA ne crée rien : elle révèle nos angles morts." },
  { nom: 'Instrument secondaire', desc: "l'IA propose, l'enseignant·e accompagne, l'apprenant·e décide." },
  { nom: 'Autonomie à construire', desc: 'non un état, mais une compétence.' },
];
---
<Base title="Résultats clés" description="La synthèse du corpus : ce que l'IA a pris en charge, comment les suggestions ont été reçues, trois démentis, trois phénomènes et trois concepts. Données agrégées et anonymes.">
  <section class="section container">
    <nav aria-label="Fil d'Ariane" class="kw-label">
      <a href={url('/memoire')}>Le mémoire</a> · Résultats clés
    </nav>
    <h1>Résultats clés</h1>
    <p class="prose">
      15 parcours d'écriture complets (7 en B1, 8 en B2), une même tâche déclinée selon le niveau,
      analysés en recherche-action et triangulés (traces écrites + questionnaire + entretien
      enseignant). Cette page en présente la synthèse ; le corpus détaillé figure dans le mémoire.
    </p>
  </section>

  <section class="section container" aria-labelledby="chiffres-h">
    <h2 id="chiffres-h">Les chiffres</h2>
    {chiffres.map((g) => (
      <div class="res-groupe">
        <h3 class="res-groupe__titre">{g.titre}</h3>
        <dl class="stats">
          {g.stats.map((s) => (
            <div class="stat"><dt class="stat__label">{s.label}</dt><dd class="stat__num">{s.num}</dd></div>
          ))}
        </dl>
      </div>
    ))}

    <aside class="callout" aria-labelledby="declare-h">
      <p id="declare-h" class="callout__title">Déclaré vs observé</p>
      <p class="prose">
        <strong>16/18</strong> déclarent savoir formuler des demandes efficaces  ≠  <strong>0</strong>
        prompt élaboré dans les traces.
      </p>
      <p class="prose res-fleche"><em>→ le sentiment de compétence devance la pratique.</em></p>
    </aside>
  </section>

  <section class="section container" aria-labelledby="dementis-h">
    <h2 id="dementis-h">Les trois démentis</h2>
    <ul class="cards cards--3">
      {dementis.map((d) => (
        <li class="res-card">
          <span class="card__index" aria-hidden="true">{d.num}</span>
          <h3 class="card__title">{d.titre}</h3>
          <p class="card__desc">{d.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section container" aria-labelledby="phenomenes-h">
    <h2 id="phenomenes-h">Trois phénomènes observés</h2>
    <ul class="cards cards--3">
      {phenomenes.map((p) => (
        <li class="res-card">
          <h3 class="card__title">{p.titre}</h3>
          <p class="card__desc">{p.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section container" aria-labelledby="concepts-h">
    <h2 id="concepts-h">Les trois concepts</h2>
    <ul class="concepts-fin">
      {concepts.map((c) => (
        <li class="concepts-fin__item">
          <p class="concepts-fin__nom">{c.nom}</p>
          <p class="concepts-fin__desc">{c.desc}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section container">
    <p class="res-note">
      Les productions des étudiant·es ne sont pas reproduites. Le corpus complet et son analyse
      figurent dans le mémoire, non publié, conformément au RGPD et au consentement recueilli pour un
      usage de recherche.
    </p>
    <p class="prose"><a href={url('/memoire')}>Revenir au mémoire</a></p>
  </section>
</Base>
