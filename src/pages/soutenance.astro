---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { diaposSvg } from '../data/diapos-svg';

const diapos = (await getCollection('soutenance')).sort((a, b) => a.data.numero - b.data.numero);
const total = diapos.length;
---
<Base title="La soutenance" description="La soutenance de master 2 FLES : le diaporama de la présentation orale, navigable et projetable en plein écran.">
  <section class="section container" id="intro-soutenance">
    <h1>La soutenance</h1>
    <p class="prose">Le diaporama de la présentation orale, en {total} diapositives. Naviguez avec les flèches et projetez-le en plein écran.</p>
    <div class="present-actions">
      <button type="button" class="btn btn--primary" data-deck-fs>Plein écran</button>
      <span class="kw-label">Navigation : ← → · plein écran : F</span>
    </div>

    <nav class="quicknav" aria-label="Diapositives">
      <ul class="quicknav__list">
        {diapos.map((d, idx) => (
          <li><a class="quicknav__link" href={`#diapo-${d.data.numero}`} data-deck-goto={idx}>{d.data.numero}. {d.data.titre}</a></li>
        ))}
      </ul>
    </nav>
  </section>

  <div id="diapos" class="deck" data-deck>
    <div class="deck__viewport" data-deck-stage>
      {diapos.map((d, idx) => (
        <section
          class="deck__slide"
          id={`diapo-${d.data.numero}`}
          data-slide
          aria-roledescription="diapositive"
          aria-label={`Diapositive ${d.data.numero} sur ${total} : ${d.data.titre}`}
        >
          <div class="deck__art" aria-hidden="true" set:html={diaposSvg[idx]} />
          <div class="deck__alt visually-hidden">
            <h2>{d.data.titre}</h2>
            {d.data.sousTitre && <p>{d.data.sousTitre}</p>}
            {d.data.meta.map((m) => <p>{m}</p>)}
            {d.data.blocs.map((b) => (
              b.items.length === 0 && b.soustitre
                ? <p>{b.soustitre}</p>
                : <div>
                    {b.soustitre && <h3>{b.soustitre}</h3>}
                    <ul>{b.items.map((i) => <li>{i}</li>)}</ul>
                  </div>
            ))}
            {d.data.signature.length > 0 && (
              <ul aria-label="Fil conducteur">{d.data.signature.map((s) => <li>{s}</li>)}</ul>
            )}
          </div>
        </section>
      ))}
    </div>

    <p class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" data-deck-live></p>

    <div class="deck__bar" role="group" aria-label="Navigation des diapositives">
      <button type="button" class="deck__btn" data-deck-prev aria-label="Diapositive précédente">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
        <span>Précédent</span>
      </button>
      <span class="deck__counter" aria-hidden="true"><span data-deck-now>1</span> / {total}</span>
      <button type="button" class="deck__btn" data-deck-next aria-label="Diapositive suivante">
        <span>Suivant</span>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
      </button>
      <button type="button" class="deck__btn deck__btn--fs" data-deck-fs aria-label="Plein écran" aria-pressed="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3M3 16v3a2 2 0 0 0 2 2h3m13-5v3a2 2 0 0 1-2 2h-3"></path></svg>
        <span>Plein écran</span>
      </button>
    </div>
  </div>
</Base>

<script>
  import '../scripts/presentation.ts';
</script>
