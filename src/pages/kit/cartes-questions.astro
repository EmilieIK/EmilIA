---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/paths';

const questions = (await getCollection('questions')).sort(
  (a, b) => parseInt(a.id.slice(1), 10) - parseInt(b.id.slice(1), 10)
);
---
<Base title="Le jeu de cartes-questions" description="Dix cartes-questions pour prendre du recul sur l'usage de l'IA dans l'écriture (étape bilan du kit).">
  <section class="section container">
    <nav aria-label="Fil d'Ariane" class="kw-label">
      <a href={url('/kit')}>Le kit</a> · <a href={url('/kit#etape-cap-sur-le-bilan')}>Étape 8</a> · Le jeu de cartes-questions
    </nav>
    <h1>Le jeu de cartes-questions</h1>
    <p class="prose">
      Chaque carte invite à une prise de recul et de parole. Dix questions, à consulter seul·e ou à
      imprimer pour la classe (étape 8).
    </p>
  </section>

  <section class="section container" aria-labelledby="jeu-h">
    <h2 id="jeu-h">Les dix cartes-questions</h2>
    <button type="button" class="btn btn--secondary" data-cq-print>Imprimer le jeu complet</button>
    <ol class="cq-deck">
      {questions.map((q, i) => (
        <li class="cq-card cq-card--static">
          <span class="cq-card__num" aria-hidden="true">{i + 1}</span>
          <p class="cq-card__q"><span class="visually-hidden">Carte {i + 1} : </span>{q.data.question}</p>
        </li>
      ))}
    </ol>
    <p class="prose"><a href={url('/kit#etape-cap-sur-le-bilan')}>Revenir à l'étape 8 du kit</a></p>
  </section>
</Base>

<script>
  document.querySelector('[data-cq-print]')?.addEventListener('click', () => window.print());
</script>
