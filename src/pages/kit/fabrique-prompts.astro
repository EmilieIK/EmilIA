---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/paths';
import BoutonCopier from '../../components/BoutonCopier.astro';

const prompts = (await getCollection('prompts')).sort((a, b) => a.id.localeCompare(b.id));
---
<Base title="La fabrique à prompts" description="Des exemples de prompts par fonction pour mobiliser l'IA comme outil linguistique ciblé en production écrite FLE.">
  <section class="section container">
    <nav aria-label="Fil d'Ariane" class="kw-label">
      <a href={url('/kit')}>Le kit</a> · <a href={url('/kit#etape-boite-a-outils-ia')}>Étape 4</a> · La fabrique à prompts
    </nav>
    <h1>La fabrique à prompts</h1>
    <p class="prose">
      Formulez un prompt clair, ne donnez pas votre texte à corriger, et demandez un soutien sur
      un point précis. Voici six fonctions utiles et un exemple de prompt pour chacune, à copier
      puis à adapter à votre besoin.
    </p>

    <p class="visually-hidden" role="status" aria-live="polite" aria-atomic="true" data-copie-live></p>

    <section aria-labelledby="fonctions-h">
      <h2 id="fonctions-h">Exemples de prompts par fonction</h2>
      <ul class="prompts">
        {prompts.map((p) => (
          <li class="prompt">
            <h3 class="prompt__fonction">{p.data.fonction}</h3>
            <p class="prompt__texte" id={`prompt-${p.id}`}>{p.data.prompt}</p>
            <BoutonCopier cible={`prompt-${p.id}`} etiquette={p.data.fonction} kind="prompt" />
          </li>
        ))}
      </ul>
    </section>

    <aside class="callout" aria-labelledby="astuce-h">
      <h2 id="astuce-h" class="callout__title">Astuce</h2>
      <p>
        Utilisez des verbes précis (proposer, vérifier, reformuler, expliquer) ; évitez les
        demandes vagues comme «&nbsp;Améliore mon texte&nbsp;».
      </p>
    </aside>

    <section aria-labelledby="fiche-h">
      <h2 id="fiche-h">Fiche imprimable</h2>
      <p class="prose">Imprimez les six exemples de prompts pour les garder sous la main en classe.</p>
      <button type="button" class="btn btn--secondary" data-print-fiche>Imprimer la fiche des 6 prompts</button>
    </section>

    <p class="prose"><a href={url('/kit#etape-boite-a-outils-ia')}>Revenir à l'étape 4 du kit</a></p>
  </section>
</Base>

<script>
  import '../../scripts/copier.ts';
  document.querySelector('[data-print-fiche]')?.addEventListener('click', () => window.print());
</script>
